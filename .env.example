# tsg-lazer — osu! lazer server dla taksiegra.ovh
# Skopiuj jako .env i uzupełnij

# Server
DEBUG=false
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8001

# Database — osobna baza od bancho-py-ex
DATABASE_URL=mysql+asyncmy://tsg_lazer:HASLO@localhost:3306/tsg_lazer

# Redis — DB 1 (bancho używa 0)
REDIS_URL=redis://localhost:6379/1

# JWT — wygeneruj: openssl rand -hex 32
SECRET_KEY=WYGENERUJ_LOSOWY_KLUCZ

# OAuth2 — musi być zgodny z patche lazer klienta
OAUTH_CLIENT_ID=5
OAUTH_CLIENT_SECRET=TWOJ_SECRET_DO_KLIENTA

# tsg URLs
API_BASE_URL=https://taksiegra.ovh
WEBSITE_URL=https://taksiegra.ovh

# Beatmap mirror (nerinyan — ten sam co w bancho-py-ex)
BEATMAP_MIRROR_URL=https://api.nerinyan.moe

# osu! API v2 (opcjonalne, do wyszukiwania beatmap)
OSU_API_CLIENT_ID=
OSU_API_CLIENT_SECRET=
